# ─── RoomEase Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MongoDB connection string
# For local Docker Compose development:
MONGO_URI=mongodb://mongo:27017/roomease
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/roomease?retryWrites=true&w=majority

# Server port
PORT=3000

# Environment: development | production
NODE_ENV=development

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin credentials
ADMIN_UID=uid1234
ADMIN_PASS=maa@12345

# SMS Notifications (Fast2SMS — https://www.fast2sms.com)
# Sign up for a free account and paste your API key below.
# If left empty, SMS notifications are disabled (violations still work, just no SMS).
FAST2SMS_API_KEY=
