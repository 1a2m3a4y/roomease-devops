{
  "name": "roomease",
  "version": "1.0.0",
  "description": "RoomEase — Hostel Management System",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:dev": "NODE_ENV=development node app.js",
    "test": "jest --forceExit --detectOpenHandles --verbose",
    "test:ci": "jest --forceExit --detectOpenHandles --ci --coverage",
